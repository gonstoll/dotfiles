{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "CONTRIBUTING.md",
    ".cursor/rules/*.md",
    ".cursor/rules/*.mdc",
    "~/.config/opencode/rules.md"
  ],
  "formatter": {
    "prettier": {
      "command": [
        "npx",
        "prettier",
        "--write",
        "$FILE",
        "--no-semi",
        "--single-quote",
        "--no-bracket-spacing",
        "--print-width",
        "80",
        "--config-precedence",
        "prefer-file"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".ts",
        ".tsx",
        ".mts",
        ".cts",
        ".html",
        ".htm",
        ".css",
        ".scss",
        ".less",
        ".vue",
        ".svelte",
        ".json",
        ".jsonc",
        ".yaml",
        ".yml",
        ".toml",
        ".xml",
        ".md",
        ".mdx",
        ".graphql",
        ".gql"
      ]
    }
  }
}

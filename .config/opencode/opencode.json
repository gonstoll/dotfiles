{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "CONTRIBUTING.md",
    "docs/*.md",
    "docs/**/*.md",
    ".cursor/rules/*.md",
    ".cursor/rules/*.mdc",
    "~/.config/opencode/rules.md"
  ],
  "formatter": {
    "prettier": {
      "command": [
        "npx",
        "prettier",
        "--write",
        "$FILE",
        "--no-semi",
        "--single-quote",
        "--no-bracket-spacing",
        "--print-width",
        "80",
        "--config-precedence",
        "prefer-file",
      ]
    }
  }
}

#!/usr/bin/env bash

DIRECTORIES=($(eval echo $(xargs < "$XDG_CONFIG_HOME/tmux-sessionizer/directories")))

function switch_to() {
    if [[ -z $TMUX ]]; then
        tmux attach-session -t "$1"
    else
        tmux switch-client -t "$1"
    fi
}

function has_session() {
    tmux list-sessions | grep -q "^$1:"
}

function hydrate() {
    if [ -f "$2/.tmux-sessionizer" ]; then
        tmux send-keys -t "$1" "source $2/.tmux-sessionizer" c-M
    elif [ -f "$XDG_CONFIG_HOME/tmux-sessionizer/default" ]; then
        tmux send-keys -t "$1" "source $XDG_CONFIG_HOME/tmux-sessionizer/default" c-M
    fi
}

if [[ $# -eq 1 ]]; then
    selected="$1"
else
    selected=$(find "${DIRECTORIES[@]}" -mindepth 1 -maxdepth 1 -type d | fzf \
            --style minimal \
            --no-bold \
            --height=100% \
            --no-unicode \
            --margin=5% \
            --no-color \
        )
fi

if [[ -z "$selected" ]]; then
    exit 0
fi

base=$(basename "$selected" | tr . _)
# To detect conflicts, this searches all configured parent directories for immediate
# subdirectories (-mindepth 1 -maxdepth 1) matching the selected directory's basename.
#
# Using -name filters at the find level to avoid listing all directories (faster).
#
# sort -u deduplicates in case overlapping directory configs surface the same path twice.
# If more than one unique match is found, the basename is ambiguous and needs a prefix.
match_count=$(find "${DIRECTORIES[@]}" -mindepth 1 -maxdepth 1 -type d -name "$(basename "$selected")" 2>/dev/null | sort -u | wc -l)

# Disambiguate directories with the same basename (e.g., ~/code/dashboard and
# ~/code/metarepo/projects/app/dashboard) by prefixing with the parent directory name.
if [[ $match_count -gt 1 ]]; then
    parent=$(basename "$(dirname "$selected")" | tr . _)
    selected_name="${parent}_${base}"
else
    selected_name="$base"
fi

tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -ds "$selected_name" -c "$selected"
    hydrate "$selected_name" "$selected"
fi

if ! has_session "$selected_name"; then
    tmux new-session -ds "$selected_name" -c "$selected"
    hydrate "$selected_name" "$selected"
fi

switch_to "$selected_name"
